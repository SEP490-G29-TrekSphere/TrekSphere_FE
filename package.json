{
  "name": "treksphere-fe",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "biome check .",
    "check:fix": "biome check . --write",
    "check:fix:unsafe": "biome check . --write --unsafe",
    "ci": "biome ci . && pnpm typecheck",
    "preview": "vite preview",
    "prepare": "lefthook install || true",
    "typecheck": "tsc --noEmit",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@react-oauth/google": "^0.13.5",
    "@shadcn/react": "^0.2.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.2",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.2",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "globe.gl": "^2.32.2",
    "gsap": "^3.15.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.5",
    "@babel/preset-react": "^7.29.5",
    "@babel/preset-typescript": "^7.29.5",
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "babel-jest": "^30.4.1",
    "babel-plugin-transform-vite-meta-env": "^1.0.3",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lefthook": "^2.1.9",
    "postcss": "^8.5.16",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.2",
    "vite": "^8.1.3",
    "vite-plugin-svgr": "^5.2.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-router|@remix-run)/)"
    ]
  }
}
