{
  "name": "treksphere-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "pnpm biome check --max-diagnostics=none --no-errors-on-unmatched",
    "lint:fix": "pnpm biome check . --write --no-errors-on-unmatched",
    "format": "pnpm biome format . --write",
    "format:check": "pnpm biome check",
    "ci": "pnpm lint && pnpm format:check && pnpm typecheck",
    "ci:fix": "pnpm lint:fix && pnpm format",
    "preview": "vite preview",
    "prepare": "lefthook install",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
